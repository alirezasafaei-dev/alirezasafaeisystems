id: persiantoolbox
name: PersianToolbox
owner: platform+product
status: production_app_layer
critical: true

source:
  path: sites/live/persiantoolbox
  vcs: git

deploy:
  registry_site: persiantoolbox
  prod_port: 3100
  staging_port: 3200
  health: /api/ready
  strategy: symlink
  runtime: node-standalone

ownership:
  code: alirezasafaei-dev
  ops: AUTOMATION_HOST
  runtime: IRAN_PROD

docs:
  readme: README.md

checks:
  health: /api/ready
  health_alt: /api/health

rollback:
  mode: symlink-previous
  notes: first production release may have empty previous_release; redeploy pin as recovery
