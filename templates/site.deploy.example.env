# ASDEV Site Deployment Environment Configuration
# Copy this file to .env and customize for your site

# Site Configuration
SITE_NAME=your-site-name
SITE_URL=https://your-site.com

# Deployment Paths
DEPLOY_PATH=/srv/asdev/sites/your-site-name
BACKUP_PATH=/srv/asdev/backups/your-site-name

# Healthcheck Configuration
HEALTHCHECK_URL=https://your-site.com
HEALTHCHECK_TIMEOUT=10
HEALTHCHECK_RETRIES=3

# Site Criticality
# Options: normal, critical
CRITICALITY=normal

# Approval Required
# Set to true if this site requires approval for production deploys
APPROVAL_REQUIRED=true

# Git Configuration
GIT_BRANCH=main
GIT_REMOTE=origin

# Release Management
KEEP_RELEASES=5
QUARANTINE_DAYS=7
BACKUP_RETENTION_DAYS=30

# Application Configuration
APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password

# Cache Configuration
CACHE_DRIVER=redis
CACHE_HOST=localhost
CACHE_PORT=6379

# Session Configuration
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Mail Configuration
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

# AWS Configuration (if using AWS)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=your-bucket

# API Keys
API_KEY=your_api_key
API_SECRET=your_api_secret

# Webhook Configuration
WEBHOOK_URL=https://your-webhook-url.com
WEBHOOK_SECRET=your_webhook_secret

# Monitoring Configuration
MONITORING_ENABLED=true
SENTRY_DSN=your_sentry_dsn

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION=30

# SSL Configuration
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/your-cert.pem
SSL_KEY_PATH=/etc/ssl/private/your-key.pem

# CDN Configuration
CDN_ENABLED=false
CDN_URL=https://your-cdn.com

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://your-site.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Logging Configuration
LOG_CHANNEL=stack
LOG_FILE=/var/log/your-site/app.log
LOG_MAX_SIZE=10
LOG_MAX_DAYS=30

# Queue Configuration
QUEUE_CONNECTION=redis
QUEUE_HOST=localhost
QUEUE_PORT=6379

# Broadcasting Configuration
BROADCAST_DRIVER=redis
BROADCAST_HOST=localhost
BROADCAST_PORT=6379

# Telescope Configuration (if using Laravel Telescope)
TELESCOPE_ENABLED=false

# Horizon Configuration (if using Laravel Horizon)
HORIZON_ENABLED=false

# Passport Configuration (if using Laravel Passport)
PASSPORT_PERSONAL_ACCESS_CLIENT_ID=your_client_id
PASSPORT_PERSONAL_ACCESS_CLIENT_SECRET=your_client_secret

# Sanctum Configuration (if using Laravel Sanctum)
SANCTUM_STATEFUL_DOMAINS=your-site.com

# Socialite Configuration (if using Socialite)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URL=https://your-site.com/auth/callback

# Firebase Configuration (if using Firebase)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# Pusher Configuration (if using Pusher)
PUSHER_APP_ID=your_app_id
PUSHER_APP_KEY=your_app_key
PUSHER_APP_SECRET=your_app_secret
PUSHER_APP_CLUSTER=mt1

# Stripe Configuration (if using Stripe)
STRIPE_KEY=your_stripe_key
STRIPE_SECRET=your_stripe_secret
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# PayPal Configuration (if using PayPal)
PAYPAL_CLIENT_ID=your_client_id
PAYPAL_CLIENT_SECRET=your_client_secret
PAYPAL_MODE=live

# Twilio Configuration (if using Twilio)
TWILIO_SID=your_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=your_phone_number

# Mailgun Configuration (if using Mailgun)
MAILGUN_DOMAIN=your_domain
MAILGUN_SECRET=your_secret

# SendGrid Configuration (if using SendGrid)
SENDGRID_API_KEY=your_api_key

# Slack Configuration (if using Slack)
SLACK_WEBHOOK_URL=your_webhook_url
SLACK_CHANNEL=your_channel

# Discord Configuration (if using Discord)
DISCORD_WEBHOOK_URL=your_webhook_url

# Telegram Configuration (if using Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# OpenAI Configuration (if using OpenAI)
OPENAI_API_KEY=your_api_key

# Anthropic Configuration (if using Anthropic)
ANTHROPIC_API_KEY=your_api_key

# Google Cloud Configuration (if using Google Cloud)
GOOGLE_CLOUD_PROJECT_ID=your_project_id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Azure Configuration (if using Azure)
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret

# Docker Configuration (if using Docker)
DOCKER_REGISTRY=your_registry
DOCKER_USERNAME=your_username
DOCKER_PASSWORD=your_password

# Kubernetes Configuration (if using Kubernetes)
KUBE_CONFIG=/path/to/kubeconfig
KUBE_NAMESPACE=your-namespace

# Terraform Configuration (if using Terraform)
TF_VAR_access_key=your_access_key
TF_VAR_secret_key=your_secret_key
TF_VAR_region=us-east-1

# Ansible Configuration (if using Ansible)
ANSIBLE_HOST_KEY_CHECKING=False
ANSIBLE_PRIVATE_KEY_FILE=/path/to/private_key

# Custom Environment Variables
CUSTOM_VAR_1=value1
CUSTOM_VAR_2=value2
CUSTOM_VAR_3=value3