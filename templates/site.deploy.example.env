# ASDEV Site Deployment Environment Configuration
# Copy this file to .env and customize for your site.
# All values below are REDACTED placeholders.

# Site Configuration
SITE_NAME=[REDACTED_SITE_NAME]
SITE_URL=https://[REDACTED_DOMAIN]

# Deployment Paths
DEPLOY_PATH=/srv/asdev/sites/[REDACTED_SITE_NAME]
SHARED_PATH=/srv/asdev/sites/[REDACTED_SITE_NAME]/shared

# Healthcheck Configuration
HEALTHCHECK_URL_ALIAS=[REDACTED_HOST_ALIAS]
HEALTHCHECK_PATH=/api/ready
HEALTHCHECK_TIMEOUT=10
HEALTHCHECK_RETRIES=3

# Runtime
RUNTIME=node
PROCESS_NAMES=[REDACTED_PROCESS_NAMES]
BUILD_COMMAND=pnpm run build
START_COMMAND=node .next/standalone/server.js

# Environment File
ENV_FILE_ALIAS=[REDACTED_ENV_ALIAS]

# Deploy Strategy
DEPLOY_STRATEGY=symlink
ROLLBACK_STRATEGY=symlink

# Release Management
KEEP_RELEASES=5
QUARANTINE_DAYS=7

# Application Configuration
APP_ENV=[REDACTED_APP_ENV]
APP_DEBUG=false
APP_LOG_LEVEL=info

# Database Configuration (if applicable)
DB_HOST=[REDACTED_DB_HOST]
DB_PORT=[REDACTED_DB_PORT]
DB_NAME=[REDACTED_DB_NAME]
DB_USER=[REDACTED_DB_USER]
DB_PASSWORD=[REDACTED_DB_PASSWORD]

# Cache Configuration (if applicable)
CACHE_DRIVER=[REDACTED_CACHE_DRIVER]
CACHE_HOST=[REDACTED_CACHE_HOST]
CACHE_PORT=[REDACTED_CACHE_PORT]

# Monitoring (if applicable)
MONITORING_ENABLED=[REDACTED_MONITORING_ENABLED]
SENTRY_DSN=[REDACTED_SENTRY_DSN]
