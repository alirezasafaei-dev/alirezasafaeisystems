# ── Required ──────────────────────────────────────────────────────────
GITHUB_TOKEN=github_pat_xxxxxxxxxxxx

# ── Optional ──────────────────────────────────────────────────────────
# GitHub owner / organisation name (default: alirezasafaei-dev)
# GITHUB_OWNER=alirezasafaei-dev

# Comma-separated whitelist of allowed repository names.
# When empty, every repo under GITHUB_OWNER is accessible.
# ALLOWED_REPOS=alirezasafaeisystems,devatlas

# Maximum file read size in bytes (default: 1_048_576 = 1 MiB)
# MAX_FILE_BYTES=1048576

# Bind address and port (default: 127.0.0.1:8000)
# BIND_HOST=127.0.0.1
# BIND_PORT=8000
