{
  "provider": "deepseek",
  "model": "deepseek-v4-flash-free",
  "role": "code-worker",
  "permissions": {
    "persiantoolbox": "read-only",
    "auditsystems": "draft-implementation",
    "alirezasafaeisystems": "full",
    "deploy": "denied",
    "billing": "denied"
