# ASDEV Hermes Command Loop — Environment Configuration
# Copy to .env and fill in values. Never commit .env files.

# GitHub repository for command thread
ASDEV_COMMAND_REPO=alirezasafaei-dev/alirezasafaeisystems

# PR number for command thread
ASDEV_COMMAND_PR=42

# GitHub token for gh CLI (or use `gh auth login`)
GITHUB_TOKEN=change-me

# Hermes profile for task classification
HERMES_PROFILE=hermes-asdev-controller

# Hermes kanban board
HERMES_KANBAN_BOARD=asdev-audit

# State file location
ASDEV_COMMAND_STATE=docs/agent-command-center/STATE.json

# Next prompt file location
ASDEV_NEXT_PROMPT_FILE=docs/agent-command-center/NEXT_AGENT_PROMPT.md

# Report template location
ASDEV_REPORT_TEMPLATE=docs/agent-command-center/REPORT_TEMPLATE.md
