# ==============================================
# AliReza Safaei Portfolio - Environment Variables Template
# ==============================================
# Usage:
# 1) cp .env.example .env
# 2) Fill values marked as REQUIRED
# 3) Keep .env local-only (never commit)

# Runtime mode: development | test | production
NODE_ENV=production

# ------------------------------------------------
# Public brand/site config (safe for client bundle)
# ------------------------------------------------
# REQUIRED in production (must be full https URL, no trailing slash preferred)
NEXT_PUBLIC_SITE_URL=https://alirezasafaeisystems.ir

# Brand identity
NEXT_PUBLIC_BRAND_NAME=Alireza Safaei
NEXT_PUBLIC_OWNER_NAME=Alireza Safaei

# Social profiles (public)
NEXT_PUBLIC_GITHUB_URL=https://github.com/parsairaniiidev/alirezasafaeisystems
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/in/alirezasafaeisystems
NEXT_PUBLIC_TELEGRAM_URL=https://telegram.me/alirezasafaeisystems
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/alirezasafaeisystems
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/message/ANXJHRC3RKRSL1
NEXT_PUBLIC_TWITTER_URL=https://x.com/alirezasafaeisystems
NEXT_PUBLIC_TWITTER_HANDLE=@alirezasafaeisystems

# Public contact data
NEXT_PUBLIC_CONTACT_EMAIL=alirezasafaeisystems@gmail.com
NEXT_PUBLIC_CONTACT_PHONE=09001602030

# Search Console verification token (optional but recommended)
NEXT_PUBLIC_GOOGLE_VERIFICATION_CODE=not-configured

# Public copy
NEXT_PUBLIC_POSITIONING_EN=Alireza Safaei - Web Systems Engineer | End-to-end design, development, and production readiness
NEXT_PUBLIC_POSITIONING_FA=علیرضا صفایی - مهندس سیستم‌های وب | طراحی و توسعه صفر تا صد تا آمادگی واقعی برای تولید

# Analytics flags (string booleans)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_WEB_VITALS=false

# Optional font CDN (local IRANSansX is always fallback)
# When enabled, set URL to your own trusted CDN endpoint.
NEXT_PUBLIC_FONT_CDN_ENABLED=false
NEXT_PUBLIC_FONT_CDN_URL=https://alirezasafaeisystems.ir/fonts/persian.css

# ------------------------------------------------
# Admin/Auth (server-only secrets)
# ------------------------------------------------
# REQUIRED for secure admin access
ADMIN_API_TOKEN=REPLACE_WITH_ADMIN_API_TOKEN
ADMIN_USERNAME=alireza
ADMIN_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD
ADMIN_SESSION_SECRET=REPLACE_WITH_SESSION_SECRET_AT_LEAST_32_CHARS

# Session TTL in seconds (default 8h)
ADMIN_SESSION_MAX_AGE_SECONDS=28800

# ------------------------------------------------
# API hardening
# ------------------------------------------------
# Rate limiting window and max requests
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=5

# ------------------------------------------------
# Optional integrations
# ------------------------------------------------
# Redis Upstash REST for distributed rate-limit
REDIS_REST_URL=https://upstash.invalid/not-configured
REDIS_REST_TOKEN=not-configured

# Lead webhook (Slack/Discord/custom)
LEAD_NOTIFICATION_WEBHOOK_URL=https://hooks.invalid/not-configured

# ------------------------------------------------
# Database (Prisma)
# ------------------------------------------------
# Local dev default: sqlite
# Production: set to managed Postgres URL
DATABASE_URL=file:/var/lib/my-portfolio/custom.db

# ------------------------------------------------
# Telegram (bot)
# ------------------------------------------------
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_TELEGRAM_CHAT_ID
